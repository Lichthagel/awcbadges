{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "ignorePatterns": ["dist", "node_modules", ".astro", ".pnpm-store"],
  "printWidth": 80,
  "semi": true,
  "singleQuote": false,
  "sortImports": true,
  "sortPackageJson": true,
  "sortTailwindcss": true,
  "svelte": {
    "allowShorthand": true,
    "indentScriptAndStyle": true
  },
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
